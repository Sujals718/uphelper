{
  "name": "@uphelper/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "dotenv -e ../../.env -- node dist/main.js",
    "start:dev": "dotenv -e ../../.env -- nest start --watch",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest --config ./jest.config.js",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:deploy": "dotenv -e ../../.env -- prisma migrate deploy --schema=prisma/schema.prisma"
  },

  "prisma": {
  "seed": "dotenv -e ../../.env -- ts-node prisma/seed.ts"
  },

  "dependencies": {
    "@nestjs/axios": "^3.1.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/schedule": "^6.1.3",
    "@prisma/client": "^5.19.1",
    "@uphelper/shared-types": "*",
    "argon2": "^0.40.3",
    "axios": "^1.7.7",
    "bullmq": "^5.79.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.6",
    "franc": "^5.0.0",
    "ioredis": "^5.11.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/testing": "^10.4.4",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "dotenv-cli": "^7.4.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prisma": "^5.19.1",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.4",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
