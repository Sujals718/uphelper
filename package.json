{
  "name": "uphelper",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "build:types": "npm run build --workspace=packages/shared-types",
    "lint": "npm run lint --workspace=apps/api && npm run lint --workspace=apps/web",
    "test": "npm run test --workspace=apps/api",
    "test:e2e": "npm run test:e2e --workspace=apps/api",
    "build": "npm run build --workspace=packages/shared-types && npm run build --workspace=apps/api && npm run build --workspace=apps/web",
    "db:migrate": "npm run prisma:migrate --workspace=apps/api",
    "db:deploy": "npm run prisma:deploy --workspace=apps/api",
    "db:generate": "npm run prisma:generate --workspace=apps/api",
    "db:seed": "npm exec --workspace=apps/api prisma db seed -- --schema=prisma/schema.prisma"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
